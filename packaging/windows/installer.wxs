<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="DropAndDrag"
           Language="1033"
           Version="1.0.0"
           Manufacturer="DropAndDrag"
           UpgradeCode="D4E7A8B2-9C1F-45D3-8E2A-7F6B5C4A3D2E">
    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Comments="Fast cross-platform drag-and-drop shelf utility" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="ARPCOMMENTS" Value="Drag-and-drop shelf for quick access" />
    <Property Id="ARPCONTACT" Value="DropAndDrag Support" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/dropanddrag/dropanddrag" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="DropAndDrag">
          <Component Id="MainExecutable" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
            <File Id="DropAndDragExe"
                  Name="DropAndDrag.exe"
                  Source="build\Release\DropAndDrag.exe"
                  KeyPath="yes">
              <Shortcut Id="StartMenuShortcut"
                        Directory="ProgramMenuDir"
                        Name="DropAndDrag"
                        WorkingDirectory="INSTALLFOLDER"
                        Icon="DropAndDragIcon.exe"
                        IconIndex="0"
                        Advertise="yes" />
            </File>
          </Component>

          <Component Id="AppResources" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
            <File Id="ResourcesDir" Name="resources" KeyPath="yes" />
          </Component>

          <Component Id="RegistryEntries" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
            <RegistryValue Root="HKLM"
                           Key="Software\DropAndDrag"
                           Name="InstallPath"
                           Value="[INSTALLFOLDER]"
                           Type="string"
                           KeyPath="yes" />
            <RegistryValue Root="HKLM"
                           Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\[ProductName]"
                           Name="DisplayName"
                           Value="DropAndDrag"
                           Type="string" />
            <RegistryValue Root="HKLM"
                           Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\[ProductName]"
                           Name="UninstallString"
                           Value="[System64Folder]msiexec.exe /x [ProductCode]"
                           Type="string" />
            <RegistryValue Root="HKLM"
                           Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\[ProductName]"
                           Name="DisplayVersion"
                           Value="1.0.0"
                           Type="string" />
            <RegistryValue Root="HKLM"
                           Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\[ProductName]"
                           Name="Publisher"
                           Value="DropAndDrag"
                           Type="string" />
          </Component>
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ProgramMenuDir" Name="DropAndDrag" />
      </Directory>
    </Directory>

    <Feature Id="MainFeature" Title="DropAndDrag" Level="1" ConfigurableDirectory="INSTALLFOLDER">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="AppResources" />
      <ComponentRef Id="RegistryEntries" />
    </Feature>

    <Icon Id="DropAndDragIcon.exe" SourceFile="resources\icons\icon.ico" />
  </Product>
</Wix>
